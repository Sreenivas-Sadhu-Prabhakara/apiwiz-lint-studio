{
  "name": "info-version-semver",
  "templateId": "field-pattern",
  "params": { "field": "version", "match": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
  "description": "API version should be semver (e.g. 1.2.0).",
  "message": "{{description}} (at {{path}})",
  "given": "$.info",
  "severity": "warn",
  "then": { "field": "version", "function": "pattern", "functionOptions": { "match": "^[0-9]+\\.[0-9]+\\.[0-9]+$" } }
}
